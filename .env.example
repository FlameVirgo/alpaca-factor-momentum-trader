# Copy this file to `.env` and fill in your Alpaca PAPER trading keys.
# `.env` is gitignored and will NEVER be committed. Do NOT put real keys here.
#
# Get paper keys from: https://app.alpaca.markets  →  Paper account  →  "API Keys"

# Paper trading endpoint (do NOT change to the live URL until you mean it)
ALPACA_BASE_URL=https://paper-api.alpaca.markets

ALPACA_API_KEY=your_paper_key_here
ALPACA_SECRET_KEY=your_paper_secret_here
